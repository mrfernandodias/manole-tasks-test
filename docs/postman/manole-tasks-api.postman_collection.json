      "name": "Auth",
      "description": "Fluxo de autenticação. Register e Login salvam o accessToken automaticamente no environment.",
      "item": [
        {
          "name": "Register",
          "description": "Cria um usuário e salva o accessToken retornado. O e-mail usa {{$timestamp}} para evitar conflito em execuções repetidas.",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "if (response.accessToken) {",
                  "  pm.environment.set(\"accessToken\", response.accessToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Usuário Postman\",\n  \"email\": \"postman_demo_{{$timestamp}}@example.com\",\n  \"password\": \"123456\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{base_url}}/auth/register",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
